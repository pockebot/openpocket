{
  "name": "openpocket",
  "version": "0.2.3",
  "description": "OpenPocket Node.js TypeScript runtime",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SergioChan/openpocket.git"
  },
  "homepage": "https://github.com/SergioChan/openpocket",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "openpocket": "dist/cli.js",
    "openpocket-mcp": "dist/mcp/server.js"
  },
  "files": [
    "dist",
    "openpocket.config.example.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "npm run build && node --test test/*.test.mjs",
    "smoke:dual-side": "bash scripts/smoke/dual-side-smoke.sh",
    "test:special-input": "npm run build && node scripts/verify-special-input.mjs",
    "test:e2e:docker": "bash scripts/test-e2e-docker.sh",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "docs:dev": "vitepress dev frontend --host",
    "docs:build": "vitepress build frontend",
    "docs:build:vercel": "DOCS_BASE=/ vitepress build frontend",
    "docs:preview": "vitepress preview frontend --host"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@mariozechner/pi-agent-core": "^0.54.1",
    "@mariozechner/pi-ai": "^0.54.1",
    "@mariozechner/pi-coding-agent": "^0.54.1",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@sinclair/typebox": "^0.34.48",
    "@slack/bolt": "^4.6.0",
    "@slack/web-api": "^7.14.1",
    "@types/qrcode": "^1.5.6",
    "baileys": "^6.7.21",
    "discord.js": "^14.25.1",
    "node-telegram-bot-api": "^0.66.0",
    "openai": "^6.10.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "sharp": "^0.34.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/node-telegram-bot-api": "^0.64.7",
    "@vercel/blob": "^2.3.0",
    "mermaid": "^11.12.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitepress": "^1.6.4",
    "vitepress-plugin-mermaid": "^2.0.17"
  }
}
